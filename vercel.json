{
  "version": 2,
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'skip root install'",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/" }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- frontend/"
}
